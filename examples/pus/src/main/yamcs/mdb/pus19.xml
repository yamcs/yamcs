			<MetaCommand name="TC_19_6_REPORT_STATUS" shortDescription="TC[19,6] Report event-action status">
				<BaseMetaCommand metaCommandRef="pus19-tc">
					<ArgumentAssignmentList>
						<ArgumentAssignment argumentName="subtype" argumentValue="6" />
					</ArgumentAssignmentList>
				</BaseMetaCommand>
				<CommandContainer name="TC_19_6_REPORT_STATUS">
					<EntryList />
					<BaseContainer containerRef="pus19-tc" />
