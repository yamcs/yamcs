			<!-- TC[19,10] Report event-action definitions (N=0 means "all", in-band per §8.19.2.10c) -->
			<MetaCommand name="TC_19_10_REPORT_DEFS" shortDescription="TC[19,10] Report event-action definitions (N=0 = all)">
				<BaseMetaCommand metaCommandRef="pus19-tc">
