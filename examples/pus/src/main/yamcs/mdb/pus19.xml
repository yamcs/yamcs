			</MetaCommand>

			<!-- TC[19,8] Enable the event-action function (zero payload) -->
			<MetaCommand name="TC_19_8_ENABLE_FUNCTION" shortDescription="TC[19,8] Enable the event-action function">
				<BaseMetaCommand metaCommandRef="pus19-tc">
					<ArgumentAssignmentList>
						<ArgumentAssignment argumentName="subtype" argumentValue="8" />
