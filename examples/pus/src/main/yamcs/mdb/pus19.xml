					<ArgumentAssignmentList>
						<ArgumentAssignment argumentName="subtype" argumentValue="5" />
					</ArgumentAssignmentList>
				</BaseMetaCommand>
				<ArgumentList>
					<Argument name="N" argumentTypeRef="/dt/uint8" />
					<Argument name="event_ids" argumentTypeRef="event_id_array_type" />
				</ArgumentList>
				<CommandContainer name="TC_19_5_SPECIFIC">
					<EntryList>
						<ArgumentRefEntry argumentRef="N" />
