			<!-- TC[19,9] Disable the event-action function (zero payload) -->
			<MetaCommand name="TC_19_9_DISABLE_FUNCTION" shortDescription="TC[19,9] Disable the event-action function">
				<BaseMetaCommand metaCommandRef="pus19-tc">
