<?xml version="1.0" encoding="UTF-8"?>
<!--
	Sample implementation of PUS Service 20 (ST[20]) - On-Board Parameter Management.

	ST[20] maintains an on-board parameter store (param_id -> value) and lets the ground
	read (TC[20,1] -> TM[20,2]) and write (TC[20,3]) parameter values. The PUS standard
	marks the value field as "deduced" (its type/size depends on param_id); XTCE cannot
	express per-param-id type variation, so this sample fixes a mission convention: every
	on-board parameter value is a uint32 (see pus_analysis/pus20.md for the full analysis).

	In scope: TC[20,1] Report parameter values, TM[20,2] Parameter value report,
	TC[20,3] Set parameter values.
-->
<SpaceSystem name="PUS20" xmlns="http://www.omg.org/spec/XTCE/20180204"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.omg.org/spec/XTCE/20180204 https://www.omg.org/spec/XTCE/20180204/SpaceSystem.xsd">
	<Header validationStatus="Unknown" version="1.0" date="2026-07-20T00:00:00Z">
		<NoteSet>
			<Note>Sample implementation of PUS20 On-Board Parameter Management.</Note>
		</NoteSet>
	</Header>
	<TelemetryMetaData>
		<ParameterTypeSet>
			<!-- TM[20,2] entry: param_id + param_value (mission convention: value always uint32) -->
			<AggregateParameterType name="ParamEntryType">
				<MemberList>
					<Member typeRef="/dt/uint16" name="param_id"/>
					<Member typeRef="/dt/uint32" name="param_value"/>
				</MemberList>
			</AggregateParameterType>
			<ArrayParameterType name="ParamEntriesType" arrayTypeRef="ParamEntryType">
				<DimensionList>
					<Dimension>
						<StartingIndex><FixedValue>0</FixedValue></StartingIndex>
						<EndingIndex>
							<DynamicValue>
								<ParameterInstanceRef parameterRef="num_params"/>
								<LinearAdjustment intercept="-1"/>
							</DynamicValue>
						</EndingIndex>
					</Dimension>
				</DimensionList>
			</ArrayParameterType>
		</ParameterTypeSet>
		<ParameterSet>
			<Parameter parameterTypeRef="/dt/uint8" name="num_params"/>
			<Parameter parameterTypeRef="ParamEntriesType" name="param_entries"
				shortDescription="Parameter entries (param_id + param_value) for TM[20,2]"/>
		</ParameterSet>
		<ContainerSet>
			<!-- Thin base for all ST[20] packets (type==20) -->
			<SequenceContainer name="pus20-tm">
				<EntryList/>
				<BaseContainer containerRef="/PUS/pus-tm">
					<RestrictionCriteria>
						<Comparison parameterRef="/PUS/type" value="20"/>
					</RestrictionCriteria>
				</BaseContainer>
			</SequenceContainer>
			<SequenceContainer name="TM_20_2" shortDescription="TM[20,2] Parameter value report">
				<EntryList>
					<ParameterRefEntry parameterRef="num_params"/>
					<ArrayParameterRefEntry parameterRef="param_entries">
						<IncludeCondition>
							<Comparison parameterRef="num_params" comparisonOperator="&gt;" value="0"/>
						</IncludeCondition>
					</ArrayParameterRefEntry>
				</EntryList>
				<BaseContainer containerRef="pus20-tm">
					<RestrictionCriteria>
						<Comparison parameterRef="/PUS/subtype" value="2"/>
					</RestrictionCriteria>
				</BaseContainer>
			</SequenceContainer>
		</ContainerSet>
	</TelemetryMetaData>
	<CommandMetaData>
		<ArgumentTypeSet>
			<IntegerArgumentType name="NumParamsType" baseType="/dt/uint8"/>

			<!-- TC[20,1] instruction: just the param_id to read -->
			<ArrayArgumentType name="ParamIdArrayType" arrayTypeRef="/dt/uint16">
				<DimensionList>
					<Dimension>
						<StartingIndex><FixedValue>0</FixedValue></StartingIndex>
						<EndingIndex>
							<DynamicValue>
								<ArgumentInstanceRef argumentRef="num_params"/>
								<LinearAdjustment intercept="-1"/>
							</DynamicValue>
						</EndingIndex>
					</Dimension>
				</DimensionList>
			</ArrayArgumentType>

			<!-- TC[20,3] instruction: param_id + new param_value (mission convention: value always uint32) -->
			<AggregateArgumentType name="SetParamEntryType">
				<MemberList>
					<Member typeRef="/dt/uint16" name="param_id"/>
					<Member typeRef="/dt/uint32" name="param_value"/>
				</MemberList>
			</AggregateArgumentType>
			<ArrayArgumentType name="SetParamEntriesType" arrayTypeRef="SetParamEntryType">
				<DimensionList>
					<Dimension>
						<StartingIndex><FixedValue>0</FixedValue></StartingIndex>
						<EndingIndex>
							<DynamicValue>
								<ArgumentInstanceRef argumentRef="num_params"/>
								<LinearAdjustment intercept="-1"/>
							</DynamicValue>
						</EndingIndex>
					</Dimension>
				</DimensionList>
			</ArrayArgumentType>
		</ArgumentTypeSet>
		<MetaCommandSet>
			<MetaCommand name="pus20-tc" abstract="true">
				<BaseMetaCommand metaCommandRef="/PUS/pus-tc">
					<ArgumentAssignmentList>
						<ArgumentAssignment argumentName="apid" argumentValue="1"/>
						<ArgumentAssignment argumentName="type" argumentValue="20"/>
					</ArgumentAssignmentList>
				</BaseMetaCommand>
				<CommandContainer name="pus20-tc">
					<EntryList/>
				</CommandContainer>
			</MetaCommand>

			<MetaCommand name="REPORT_PARAMETER_VALUES" shortDescription="TC[20,1] Report parameter values">
				<BaseMetaCommand metaCommandRef="pus20-tc">
					<ArgumentAssignmentList>
						<ArgumentAssignment argumentName="subtype" argumentValue="1"/>
					</ArgumentAssignmentList>
				</BaseMetaCommand>
				<ArgumentList>
					<Argument argumentTypeRef="NumParamsType" name="num_params"/>
					<Argument argumentTypeRef="ParamIdArrayType" name="param_ids"/>
				</ArgumentList>
				<CommandContainer name="REPORT_PARAMETER_VALUES">
					<EntryList>
						<ArgumentRefEntry argumentRef="num_params"/>
						<ArgumentRefEntry argumentRef="param_ids"/>
					</EntryList>
					<BaseContainer containerRef="pus20-tc"/>
				</CommandContainer>
				<VerifierSet>
					<ExecutionVerifier name="ParamValueReport">
						<ContainerRef containerRef="TM_20_2"/>
						<CheckWindow timeToStopChecking="PT15S" timeWindowIsRelativeTo="commandRelease"/>
					</ExecutionVerifier>
				</VerifierSet>
			</MetaCommand>

			<MetaCommand name="SET_PARAMETER_VALUES" shortDescription="TC[20,3] Set parameter values">
				<BaseMetaCommand metaCommandRef="pus20-tc">
					<ArgumentAssignmentList>
						<ArgumentAssignment argumentName="subtype" argumentValue="3"/>
					</ArgumentAssignmentList>
				</BaseMetaCommand>
				<ArgumentList>
					<Argument argumentTypeRef="NumParamsType" name="num_params"/>
					<Argument argumentTypeRef="SetParamEntriesType" name="param_entries"/>
				</ArgumentList>
				<CommandContainer name="SET_PARAMETER_VALUES">
					<EntryList>
						<ArgumentRefEntry argumentRef="num_params"/>
						<ArgumentRefEntry argumentRef="param_entries"/>
					</EntryList>
					<BaseContainer containerRef="pus20-tc"/>
				</CommandContainer>
			</MetaCommand>
		</MetaCommandSet>
	</CommandMetaData>
</SpaceSystem>
