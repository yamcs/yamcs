    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.4",
    "ng-packagr": "^22.0.0",
    "prettier": "^3.5.0",
    "typescript": "~6.0.3"
  },
  "allowScripts": {
    "@parcel/watcher": true,
